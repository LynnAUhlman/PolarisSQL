SELECT
 th.TransactionTypeID AS [TransactionTypeID],
 tt.TransactionTypeDescription AS [Transaction Type Description],
 COUNT(DISTINCT th.TransactionID) AS [Count]
FROM
 PolarisTransactions.Polaris.TransactionHeaders th WITH (NOLOCK)
INNER JOIN
 PolarisTransactions.Polaris.TransactionTypes tt WITH (NOLOCK)
   ON (tt.TransactionTypeID = th.TransactionTypeID)
WHERE
 th.TranClientDate BETWEEN '2026-01-01 00:00:00.000' AND '2026-03-31 23:59:59.999'
 AND th.OrganizationID = 10
 AND th.TransactionTypeID IN (3008,3007)
GROUP BY
 th.TransactionTypeID,
 tt.TransactionTypeDescription
ORDER BY
 [Count] DESC
